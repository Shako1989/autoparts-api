# Copy to .env on the VM and fill in real values. Never commit the real .env.

# Public hostnames (DNS A records must point at this VM)
API_HOST=api.autoparts.az
MEDIA_HOST=cdn.autoparts.az

# Postgres
POSTGRES_DB=autoparts
POSTGRES_USER=autoparts
POSTGRES_PASSWORD=change-me-to-a-strong-password

# JWT
JWT_SECRET=replace-with-at-least-32-characters-of-random-bytes
JWT_ISSUER=autoparts-api
JWT_ACCESS_TTL=P1D

# Admin allowlist (comma-separated E.164 phones; promoted to STAFF on first verify)
ADMIN_PHONES=+994501234567

# CORS — comma-separated origins the frontend is served from
CORS_ALLOWED_ORIGINS=https://www.autoparts.az,https://autoparts.az

# MinIO (object storage)
MINIO_ROOT_USER=autoparts
MINIO_ROOT_PASSWORD=change-me-to-another-strong-password
S3_REGION=us-east-1
S3_LISTINGS_BUCKET=autoparts-listings
S3_LISTINGS_PUBLIC_BASE=https://cdn.autoparts.az/autoparts-listings
S3_CATALOG_BUCKET=autoparts-catalog
S3_CATALOG_PUBLIC_BASE=https://cdn.autoparts.az/autoparts-catalog

# SMTP for OTP delivery (Brevo free tier works out of the box)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your-brevo-smtp-login
SMTP_PASSWORD=your-brevo-smtp-key
OTP_EMAIL_FROM=no-reply@autoparts.az
OTP_EMAIL_SUBJECT=Your AutoParts.az verification code

# Image tag for the API container (set after first build)
API_VERSION=latest
